---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="py-20 sm:py-24">
  <div class="mx-auto w-full max-w-4xl px-4 sm:px-6">
    <div class="relative overflow-hidden rounded-2xl border border-aiir-200 bg-gradient-to-br from-aiir-50 via-white to-aiir-50 px-6 py-14 text-center sm:px-10 dark:border-aiir-900 dark:from-aiir-950/60 dark:via-slate-950 dark:to-aiir-950/60">
      <div class="pointer-events-none absolute -left-20 -top-24 h-64 w-64 rounded-full bg-aiir-300/30 blur-3xl dark:bg-aiir-500/10"></div>
      <div class="pointer-events-none absolute -right-16 -bottom-20 h-56 w-56 rounded-full bg-aiir-400/20 blur-3xl dark:bg-aiir-500/10"></div>

      <div class="relative">
        <h2 class="text-balance text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
          {t('home.cta.title')}
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-pretty text-base leading-relaxed text-slate-600 dark:text-slate-300">
          {t('home.cta.body')}
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href={getRelativeLocaleUrl(locale, '/download')}
            class="inline-flex items-center justify-center rounded-md bg-aiir-500 px-5 py-2.5 text-sm font-medium text-white shadow-sm shadow-aiir-500/20 transition hover:bg-aiir-600 focus-visible:outline-aiir-500"
          >
            {t('home.cta.primary')}
          </a>
          <a
            href={getRelativeLocaleUrl(locale, '/docs/protocol')}
            class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white/60 px-5 py-2.5 text-sm font-medium text-slate-700 backdrop-blur transition hover:border-aiir-400 hover:text-aiir-600 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-200 dark:hover:border-aiir-500 dark:hover:text-aiir-300"
          >
            {t('home.cta.secondary')}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
