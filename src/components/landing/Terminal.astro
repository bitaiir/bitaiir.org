---
import { useTranslations, type Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section id="run-a-node" class="border-t border-slate-200/70 bg-slate-50/50 py-20 sm:py-24 dark:border-slate-800/70 dark:bg-slate-950/30">
  <div class="mx-auto grid w-full max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-[1fr_1.2fr] lg:items-center">
    <div class="max-w-xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-aiir-600 dark:text-aiir-300">
        {t('home.terminal.eyebrow')}
      </p>
      <h2 class="mt-3 text-balance text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        {t('home.terminal.title')}
      </h2>
      <p class="mt-4 text-pretty text-base leading-relaxed text-slate-600 dark:text-slate-300">
        {t('home.terminal.body')}
      </p>
    </div>

    <figure class="overflow-hidden rounded-xl border border-slate-200 bg-slate-950 text-sm shadow-lg shadow-slate-950/10 dark:border-slate-800 dark:shadow-black/30">
      <figcaption class="flex items-center gap-2 border-b border-slate-800 bg-slate-900 px-4 py-2.5 text-xs text-slate-400">
        <span class="flex gap-1.5">
          <span class="h-2.5 w-2.5 rounded-full bg-slate-700"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-slate-700"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-slate-700"></span>
        </span>
        <span class="ml-2 font-mono">{t('home.terminal.caption')}</span>
      </figcaption>
      <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-6 text-slate-200"><code><span class="text-aiir-400">bitaiir&gt;</span> <span class="text-slate-100">/mine-start</span>
<span class="text-slate-400">Mining started.</span>

<span class="text-slate-500">Height  Hash              Reward     Nonce   Time</span>
<span class="text-slate-500">------  ----------------  ---------  ------  -----</span>
     1  <span class="text-aiir-300">8c25dd…e409</span>      <span class="text-emerald-400">100 AIIR</span>   327     2.1s
     2  <span class="text-aiir-300">95ced1…4e70</span>      <span class="text-emerald-400">100 AIIR</span>    84     0.8s
     3  <span class="text-aiir-300">a14ef0…c2b1</span>      <span class="text-emerald-400">100 AIIR</span>   512     1.4s

<span class="text-aiir-400">bitaiir&gt;</span> <span class="text-slate-100">/getnewaddress</span>
<span class="text-slate-300">"aiir1KXgUaSrv31thw41QTrb3MpK9FBziQQZ8T"</span>

<span class="text-aiir-400">bitaiir&gt;</span> <span class="text-slate-100">/sendtoaddress aiir1KXg… 10</span>
<span class="text-slate-400">&#123; "txid": </span><span class="text-aiir-300">"5cbe93…"</span><span class="text-slate-400">, "status": "added to mempool" &#125;</span>

<span class="text-aiir-400">bitaiir&gt;</span> <span class="inline-block h-3.5 w-2 translate-y-0.5 animate-pulse bg-aiir-400"></span></code></pre>
    </figure>
  </div>
</section>
