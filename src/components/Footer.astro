---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();

const columns = [
  {
    title: t('footer.sections.project'),
    links: [
      { label: t('footer.links.about'), href: getRelativeLocaleUrl(locale, '/') },
      { label: t('footer.links.download'), href: getRelativeLocaleUrl(locale, '/download') },
      { label: t('footer.links.license'), href: 'https://github.com/bitaiir/bitaiir.org/blob/master/LICENSE', external: true },
    ],
  },
  {
    title: t('footer.sections.resources'),
    links: [
      { label: t('footer.links.protocol'), href: getRelativeLocaleUrl(locale, '/docs/protocol') },
      { label: t('footer.links.source'), href: 'https://github.com/bitaiir/bitaiir', external: true },
      { label: t('footer.links.security'), href: 'https://github.com/bitaiir/bitaiir/blob/master/SECURITY.md', external: true },
    ],
  },
  {
    title: t('footer.sections.community'),
    links: [
      { label: 'GitHub', href: 'https://github.com/bitaiir', external: true },
    ],
  },
];
---
<footer class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-950">
  <div class="mx-auto w-full max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-1">
        <a
          href={getRelativeLocaleUrl(locale, '/')}
          class="flex items-center gap-1.5"
          aria-label="BitAiir home"
        >
          <img
            src="/img/logo.png"
            alt=""
            class="h-7 w-7"
            width="500"
            height="500"
          />
          <span class="font-display text-2xl font-bold italic leading-none tracking-tight text-slate-800 dark:text-slate-100">
            bitaiir
          </span>
        </a>
        <p class="mt-3 max-w-xs text-sm text-slate-600 dark:text-slate-400">{t('footer.tagline')}</p>
      </div>
      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                  target={link.external ? '_blank' : undefined}
                  class="text-sm text-slate-600 transition hover:text-aiir-600 dark:text-slate-400 dark:hover:text-aiir-300"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <p class="mt-10 border-t border-slate-200 pt-6 text-xs text-slate-500 dark:border-slate-800 dark:text-slate-500">
      © {year} {t('footer.legal')}
    </p>
  </div>
</footer>
