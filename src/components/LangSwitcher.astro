---
import {
  locales,
  localeNames,
  localeShortNames,
  stripLocale,
  useTranslations,
  type Locale,
} from '~/i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const bare = stripLocale(Astro.url.pathname);
const options = locales.map((l) => ({
  locale: l,
  href: `/${l}${bare === '/' ? '/' : bare}`,
  name: localeNames[l],
  short: localeShortNames[l],
}));
---
<div class="relative">
  <details class="group">
    <summary
      class="flex cursor-pointer list-none items-center gap-1 rounded-md px-2 py-1.5 text-sm text-slate-600 transition hover:text-aiir-600 focus-visible:outline-aiir-500 dark:text-slate-300 dark:hover:text-aiir-300"
      aria-label={t('lang.switch')}
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
        <circle cx="12" cy="12" r="10" />
        <path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" />
      </svg>
      <span class="font-medium">{localeShortNames[locale]}</span>
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3 transition group-open:rotate-180">
        <path d="m6 9 6 6 6-6" />
      </svg>
    </summary>
    <div class="absolute right-0 z-50 mt-1 min-w-[10rem] overflow-hidden rounded-md border border-slate-200 bg-white py-1 shadow-lg dark:border-slate-800 dark:bg-slate-900">
      {options.map((opt) => (
        <a
          href={opt.href}
          class:list={[
            'flex items-center justify-between px-3 py-1.5 text-sm transition',
            opt.locale === locale
              ? 'text-aiir-600 dark:text-aiir-300'
              : 'text-slate-700 hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-800',
          ]}
        >
          <span>{opt.name}</span>
          <span class="text-xs text-slate-400">{opt.short}</span>
        </a>
      ))}
    </div>
  </details>
</div>
