---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Locale } from '~/i18n/ui';
import LangSwitcher from '~/components/LangSwitcher.astro';
import ThemeToggle from '~/components/ThemeToggle.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const nav = [
  { href: getRelativeLocaleUrl(locale, '/'), label: t('nav.home') },
  { href: getRelativeLocaleUrl(locale, '/docs'), label: t('nav.docs') },
  { href: getRelativeLocaleUrl(locale, '/download'), label: t('nav.download') },
  { href: getRelativeLocaleUrl(locale, '/community'), label: t('nav.community') },
];
---
<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/70 dark:border-slate-800/70 dark:bg-slate-950/80 dark:supports-[backdrop-filter]:bg-slate-950/70">
  <div class="mx-auto flex h-16 w-full max-w-6xl items-center gap-6 px-4 sm:px-6">
    <a
      href={getRelativeLocaleUrl(locale, '/')}
      class="flex items-center gap-1.5"
      aria-label="BitAiir home"
    >
      <img
        src="/img/logo.png"
        alt=""
        class="h-7 w-7"
        width="500"
        height="500"
      />
      <span class="font-display text-2xl font-bold italic leading-none tracking-tight text-slate-800 dark:text-slate-100">
        bitaiir
      </span>
    </a>

    <nav aria-label="Primary" class="ml-6 hidden items-center gap-1 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="rounded-md px-3 py-1.5 text-sm text-slate-600 transition hover:text-aiir-600 dark:text-slate-300 dark:hover:text-aiir-300"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-1">
      <a
        href="https://github.com/bitaiir/bitaiir"
        rel="noopener noreferrer"
        target="_blank"
        class="hidden rounded-md px-3 py-1.5 text-sm text-slate-600 transition hover:text-aiir-600 dark:text-slate-300 dark:hover:text-aiir-300 sm:inline-block"
      >
        {t('nav.github')}
      </a>
      <LangSwitcher locale={locale} />
      <ThemeToggle locale={locale} />
    </div>
  </div>
</header>
