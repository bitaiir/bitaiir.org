---
import { useTranslations, type Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
  enHref: string;
}

const { locale, enHref } = Astro.props;
const t = useTranslations(locale);
---
<div
  role="note"
  class="flex flex-col gap-3 rounded-lg border border-amber-300 bg-amber-50 p-4 sm:flex-row sm:items-start dark:border-amber-900 dark:bg-amber-950/40"
>
  <svg
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-5 w-5 flex-shrink-0 text-amber-600 dark:text-amber-300"
  >
    <path d="M12 9v4M12 17h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
  </svg>
  <div class="flex-1">
    <p class="text-sm font-semibold text-amber-900 dark:text-amber-100">
      {t('docs.translation.banner_title')}
    </p>
    <p class="mt-1 text-sm text-amber-800 dark:text-amber-200">
      {t('docs.translation.banner_body')}
    </p>
    <a
      href={enHref}
      class="mt-2 inline-block text-sm font-medium text-amber-900 underline decoration-amber-400 underline-offset-2 hover:text-amber-700 dark:text-amber-100 dark:decoration-amber-500 dark:hover:text-amber-50"
    >
      {t('docs.translation.banner_link')} →
    </a>
  </div>
</div>
