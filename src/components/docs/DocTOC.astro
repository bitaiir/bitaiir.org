---
import type { MarkdownHeading } from 'astro';
import { useTranslations, type Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
  headings: MarkdownHeading[];
}

const { locale, headings } = Astro.props;
const t = useTranslations(locale);

const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---
{items.length > 0 && (
  <aside class="hidden xl:sticky xl:top-20 xl:block xl:self-start">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
      {t('docs.toc.label')}
    </p>
    <ul class="space-y-1 border-l border-slate-200 text-sm dark:border-slate-800">
      {items.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            class:list={[
              '-ml-px block border-l border-transparent px-3 py-1 text-slate-600 transition hover:border-aiir-400 hover:text-aiir-600 dark:text-slate-400 dark:hover:border-aiir-500 dark:hover:text-aiir-300',
              h.depth === 3 ? 'pl-6' : '',
            ]}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}
