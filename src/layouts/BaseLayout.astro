---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '~/styles/global.css';

import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { htmlLang, useTranslations, type Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title
  ? `${title} — ${t('site.title')}`
  : `${t('site.title')} — ${t('site.tagline')}`;
const pageDescription = description ?? t('site.description');
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://bitaiir.org').toString();
---
<!doctype html>
<html lang={htmlLang[locale]} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1294d7" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/img/logo.png" />
    <meta name="twitter:card" content="summary" />

    <link rel="alternate" hreflang="en" href={new URL(`/en${Astro.url.pathname.replace(/^\/(en|pt-br)/, '') || '/'}`, Astro.site ?? 'https://bitaiir.org').toString()} />
    <link rel="alternate" hreflang="pt-BR" href={new URL(`/pt-br${Astro.url.pathname.replace(/^\/(en|pt-br)/, '') || '/'}`, Astro.site ?? 'https://bitaiir.org').toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL('/en/', Astro.site ?? 'https://bitaiir.org').toString()} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('bitaiir-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          var useDark = stored
            ? stored === 'dark'
            : prefersDark || !prefersLight;
          if (useDark) document.documentElement.classList.add('dark');
        } catch (_) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
