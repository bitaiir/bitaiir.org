---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { locales, useTranslations, type Locale } from '~/i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const cards = [
  {
    key: 'github',
    href: 'https://github.com/bitaiir',
    icon: 'github' as const,
    external: true,
  },
  {
    key: 'twitter',
    href: 'https://x.com/BitAiir',
    icon: 'x' as const,
    external: true,
  },
  {
    key: 'telegram',
    href: 'https://t.me/BitAiir',
    icon: 'telegram' as const,
    external: true,
  },
  {
    key: 'contact',
    href: 'mailto:contact@bitaiir.org',
    icon: 'mail' as const,
    external: false,
  },
  {
    key: 'security',
    href: 'mailto:security@bitaiir.org',
    icon: 'shield' as const,
    external: false,
  },
  {
    key: 'contribute',
    href: 'https://github.com/bitaiir/bitaiir/blob/master/CONTRIBUTING.md',
    icon: 'pull-request' as const,
    external: true,
  },
];
---
<BaseLayout locale={lang} title={t('community.title')} description={t('community.subtitle')}>
  <section class="mx-auto w-full max-w-5xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="text-sm font-semibold uppercase tracking-widest text-aiir-600 dark:text-aiir-300">
      {t('community.eyebrow')}
    </p>
    <h1 class="mt-3 text-balance text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
      {t('community.title')}
    </h1>
    <p class="mt-4 max-w-2xl text-pretty text-base text-slate-600 dark:text-slate-300">
      {t('community.subtitle')}
    </p>
  </section>

  <section class="mx-auto w-full max-w-5xl px-4 pb-24 sm:px-6">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => (
        <a
          href={card.href}
          rel={card.external ? 'noopener noreferrer' : undefined}
          target={card.external ? '_blank' : undefined}
          class="group flex flex-col rounded-xl border border-slate-200 bg-white p-6 transition hover:border-aiir-400 hover:shadow-md dark:border-slate-800 dark:bg-slate-900 dark:hover:border-aiir-700"
        >
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-aiir-50 text-aiir-600 ring-1 ring-aiir-100 dark:bg-aiir-950/50 dark:text-aiir-300 dark:ring-aiir-900">
            {card.icon === 'github' && (
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02.8-.22 1.65-.33 2.5-.33s1.7.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85V21c0 .27.16.58.67.48A10 10 0 0 0 22 12 10 10 0 0 0 12 2z" />
              </svg>
            )}
            {card.icon === 'x' && (
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.83l4.713 6.231 5.447-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z" />
              </svg>
            )}
            {card.icon === 'telegram' && (
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M21.95 4.6c.4-1.7-.6-2.4-1.7-2L2.6 9.4c-1.5.6-1.5 1.4-.3 1.8l4.6 1.4 10.7-6.7c.5-.3 1-.1.6.2L8.6 14l-.3 4.7c.6 0 .9-.3 1.2-.6l3-2.9 4.7 3.5c.9.5 1.5.2 1.7-.8l3-13.3z" />
              </svg>
            )}
            {card.icon === 'mail' && (
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="m3 7 9 7 9-7" />
              </svg>
            )}
            {card.icon === 'shield' && (
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            )}
            {card.icon === 'pull-request' && (
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <circle cx="6" cy="6" r="2.5" />
                <circle cx="6" cy="18" r="2.5" />
                <circle cx="18" cy="18" r="2.5" />
                <path d="M6 8.5v7M16 11V8a3 3 0 0 0-3-3h-2.5" />
                <path d="M13 2.5 10.5 5 13 7.5" />
              </svg>
            )}
          </div>
          <h2 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">
            {t(`community.cards.${card.key}.title`)}
          </h2>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
            {t(`community.cards.${card.key}.body`)}
          </p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-aiir-600 group-hover:text-aiir-700 dark:text-aiir-300 dark:group-hover:text-aiir-200">
            {t(`community.cards.${card.key}.cta`)} →
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
