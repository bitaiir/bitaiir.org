---
import { getCollection, getEntry, render } from 'astro:content';
import DocLayout from '~/layouts/DocLayout.astro';
import type { Locale } from '~/i18n/ui';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => {
    const [, ...rest] = entry.id.split('/');
    const last = rest[rest.length - 1];
    const routeSegs = last === 'index' ? rest.slice(0, -1) : rest;
    const lang = entry.id.split('/')[0];
    return {
      params: {
        lang,
        slug: routeSegs.length > 0 ? routeSegs.join('/') : undefined,
      },
      props: { entry },
    };
  });
}

type DocEntry = Awaited<ReturnType<typeof getCollection<'docs'>>>[number];
const { entry } = Astro.props as { entry: DocEntry };

const lang = entry.id.split('/')[0] as Locale;

// Fall back to the English counterpart when the localized stub has no body.
let renderEntry: DocEntry = entry;
let enHref: string | undefined;
if (entry.data.translated === false) {
  const enId = entry.id.replace(/^pt-br\//, 'en/');
  const enEntry = await getEntry('docs', enId);
  if (enEntry) {
    renderEntry = enEntry;
    const [, ...enRest] = enId.split('/');
    const last = enRest[enRest.length - 1];
    const segs = last === 'index' ? enRest.slice(0, -1) : enRest;
    enHref = `/en/docs/${segs.join('/')}`;
  }
}

const { Content, headings } = await render(renderEntry);

// Build the section navigation — peers share the first two path segments
// (locale + section, e.g. "en/protocol").
const idParts = entry.id.split('/');
const sectionPrefix = `${idParts[0]}/${idParts[1]}/`;
const peers = (
  await getCollection('docs', (e) => e.id.startsWith(sectionPrefix))
).sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const currentIdx = peers.findIndex((e) => e.id === entry.id);
const prevEntry = currentIdx > 0 ? peers[currentIdx - 1] : null;
const nextEntry = currentIdx < peers.length - 1 ? peers[currentIdx + 1] : null;
---
<DocLayout
  locale={lang}
  title={entry.data.title}
  description={entry.data.description}
  status={entry.data.status}
  translated={entry.data.translated}
  updated={entry.data.updated}
  headings={headings}
  peers={peers}
  currentId={entry.id}
  prevEntry={prevEntry}
  nextEntry={nextEntry}
  enHref={enHref}
>
  <Content />
</DocLayout>
