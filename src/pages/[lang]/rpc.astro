---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CodeBlock from '~/components/CodeBlock.astro';
import { locales, useTranslations, type Locale } from '~/i18n/ui';
import { RPC_COMMANDS, RPC_GROUPS, type RpcGroup } from '~/data/rpc-commands';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const commandsByGroup: Record<RpcGroup, typeof RPC_COMMANDS> = {
  chain: [],
  wallet: [],
  mining: [],
  peers: [],
  aliases: [],
  escrow: [],
  daemon: [],
};
for (const cmd of RPC_COMMANDS) {
  commandsByGroup[cmd.group].push(cmd);
}
---
<BaseLayout locale={lang} title={t('rpc.title')} description={t('rpc.subtitle')}>
  <section class="mx-auto w-full max-w-5xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="text-sm font-semibold uppercase tracking-widest text-aiir-600 dark:text-aiir-300">
      {t('rpc.eyebrow')}
    </p>
    <h1 class="mt-3 text-balance text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
      {t('rpc.title')}
    </h1>
    <p class="mt-4 max-w-2xl text-pretty text-base text-slate-600 dark:text-slate-300">
      {t('rpc.subtitle')}
    </p>
  </section>

  <section class="mx-auto w-full max-w-5xl px-4 pb-12 sm:px-6">
    <div class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
        {t('rpc.intro_summary')}
      </h2>
      <div class="mt-4 grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-3">
        {RPC_GROUPS.map((group) => {
          const cmds = commandsByGroup[group];
          if (cmds.length === 0) return null;
          return (
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-aiir-600 dark:text-aiir-300">
                {t(`rpc.groups.${group}`)}
              </p>
              <ul class="mt-2 space-y-1">
                {cmds.map((cmd) => (
                  <li>
                    <a
                      href={`#${cmd.name}`}
                      class="font-mono text-sm text-slate-700 transition hover:text-aiir-600 dark:text-slate-300 dark:hover:text-aiir-300"
                    >
                      {cmd.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-3xl px-4 pb-24 sm:px-6">
    {RPC_GROUPS.map((group) => {
      const cmds = commandsByGroup[group];
      if (cmds.length === 0) return null;
      return (
        <div class="mt-16 first:mt-0">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
            {t(`rpc.groups.${group}`)}
          </h2>
          <div class="mt-6 space-y-12">
            {cmds.map((cmd) => (
              <article id={cmd.name} class="scroll-mt-24">
                <h3 class="font-mono text-lg font-semibold text-aiir-600 dark:text-aiir-300">
                  {cmd.signature}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                  {cmd.description[lang]}
                </p>

                <div class="mt-4">
                  <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                    {t('rpc.labels.params')}
                  </p>
                  {cmd.params.length === 0 ? (
                    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
                      {t('rpc.labels.no_params')}
                    </p>
                  ) : (
                    <ul class="mt-2 space-y-1.5">
                      {cmd.params.map((p) => (
                        <li class="text-sm">
                          <code class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[13px] text-slate-800 dark:bg-slate-800 dark:text-slate-100">
                            {p.name}
                          </code>
                          <span class="ml-2 text-slate-500 dark:text-slate-400">{p.type}</span>
                          <span class="ml-2 text-xs text-slate-400 dark:text-slate-500">
                            {p.required ? t('rpc.labels.required') : t('rpc.labels.optional')}
                          </span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>

                <div class="mt-4">
                  <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                    {t('rpc.labels.example')}
                  </p>
                  <CodeBlock
                    lang="bash"
                    code={cmd.cliExample}
                    copyLabel={t('common.copy')}
                    copiedLabel={t('common.copied')}
                  />
                </div>

                <div class="mt-2">
                  <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                    {t('rpc.labels.response')}
                  </p>
                  <CodeBlock
                    lang="json"
                    code={cmd.responseExample}
                    copyLabel={t('common.copy')}
                    copiedLabel={t('common.copied')}
                  />
                </div>
              </article>
            ))}
          </div>
        </div>
      );
    })}
  </section>
</BaseLayout>
